// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String
  nickname     String
  profileImage String?

  // SQLite는 Enum을 지원하지 않으므로 String으로 저장
  // 애플리케이션에서 UserRole, UserStatus Enum으로 매핑
  role   String @default("USER") // USER, ADMIN
  status String @default("ACTIVE") // ACTIVE, SUSPENDED, DELETED

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relations
  socialAccounts SocialAccount[]
  wallet         Wallet?
  points         Point[]
  transactions   WalletTransaction[]

  @@map("users")
}

model SocialAccount {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)


  provider   String 
  providerId String // 소셜 플랫폼에서 제공하는 고유 ID
  email      String // 해당 소셜의 이메일
  isPrimary  Boolean @default(false) // 첫 가입 계정 여부

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId]) // 같은 플랫폼의 같은 ID는 1개만
  @@index([userId])
  @@map("social_accounts")
}

model Wallet {
  userId    Int      @id
  cash      Int      @default(0)
  point     Int      @default(0)
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Point {
  id     Int @id @default(autoincrement())
  userId Int

  amount    Int
  remaining Int
  earnedAt  DateTime @default(now())
  expiresAt DateTime

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointUsage PointUsage[]

  @@index([userId, expiresAt])
  @@index([userId, remaining])
  @@map("points")
}

model PointUsage {
  id            Int      @id @default(autoincrement())
  transactionId Int
  pointId       Int
  usedAmount    Int
  createdAt     DateTime @default(now())

  transaction WalletTransaction @relation(fields: [transactionId], references: [id])
  point       Point             @relation(fields: [pointId], references: [id])
}

enum CurrencyType {
  CASH
  POINT
}

enum TransactionType {
  EARN // 획득
  USE // 사용
  EXPIRE // 만료
}

enum SourceType {
  // === 포인트 획득 ===
  COUPON_REDEEM // 쿠폰 사용
  ATTENDANCE_LOG // 출석체크 기록
  ROULETTE_LOG // 룰렛 결과 기록
  COMPENSATION // 보상/보전

  // === 포인트 만료 ===
  POINT_EXPIRED // 포인트 만료

  // === 캐시 획득 ===
  ORDER // 주문/결제 테이블
  ROULETTE_REWARD_CASH // 룰렛 보상 (캐시)

  // === 캐시소멸 ===
  REFUND // 결제 취소로 인한 환불

  // === 캐시/포인트 획득 ===
  ADMIN_GRANT // 관리자 수동 지급

  // === 재화 사용 ===
  ROULETTE_SPIN // 룰렛 사용
  ITEM_PURCHASE // 아이템 상점 구매
}

model WalletTransaction {
  id     Int @id @default(autoincrement())
  userId Int

  currencyType CurrencyType
  changeType   TransactionType

  // [원천 추적] 
  sourceType SourceType
  sourceId   String // 실제 도메인 테이블의 PK (주문번호, 쿠폰번호 등)

  // [금액 정보]
  amount       Int // 변동 금액
  balanceAfter Int // 변동 후 잔액 (스냅샷)

  // [기타]
  metadata  Json? // 추가 정보 (어드민 메모, 환불 ID 등)
  createdAt DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointUsage PointUsage[]

  // 인덱스 설계: 추적과 조회를 위한 핵심
  @@index([sourceType, sourceId]) // 멱등성 체크 및 원천 데이터 추적용
  @@index([userId, createdAt]) // 마이페이지 내역 조회용
  @@map("wallet_transactions")
}
